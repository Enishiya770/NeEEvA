crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ===== Project local =====
# Bundled GPT-SoVITS runtime + models (~12GB, far beyond GitHub limits).
# Keep the start script tracked so cloners see how the server is launched.
/GPT-SoVITS/*
!/GPT-SoVITS/start_tts_server.bat
# User-created singing clips are private runtime data, never source assets.
/Server/SenseVoice/song_library/
/Server/SenseVoice/song_catalog.json
/Server/RuntimeLogs/
**/__pycache__/
*.py[cod]
# Claude Code local session config
.claude/
# Local API key backup (removed from scenes before publishing)
LOCAL_API_KEYS.backup.txt
# Stray empty git-init leftover folder
/git/
# Local Seed-VC runtime dependencies and downloaded model weights
Server/SeedVC/python_packages/
Server/SeedVC/vendor/
Server/SeedVC/local_models/
